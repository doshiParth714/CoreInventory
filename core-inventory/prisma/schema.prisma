generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OperationType {
  RECEIPT
  DELIVERY
  TRANSFER
  ADJUSTMENT
}

enum PickingStatus {
  DRAFT
  CONFIRM
  READY
  DONE
  CANCELLED
}

enum MoveStatus {
  DRAFT
  WAITING
  READY
  DONE
  CANCELLED
}

model Profile {
  id        String   @id
  loginId   String   @unique
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  receipts    StockPicking[]        @relation("ResponsibleReceipts")
  adjustments InventoryAdjustment[] @relation("ResponsibleAdjustments")
}

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  shortCode String   @unique
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  locations Location[]
}

model Location {
  id          String   @id @default(cuid())
  name        String
  shortCode   String
  warehouseId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  stockFrom     StockPicking[] @relation("FromLocation")
  stockTo       StockPicking[] @relation("ToLocation")
  stockLines    StockMoveLine[]
  productStocks ProductStock[]
  adjustments   InventoryAdjustment[]

  @@unique([shortCode, warehouseId])
}

model ProductCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id           String   @id @default(cuid())
  name         String
  sku          String   @unique
  categoryId   String
  unitOfMeasure String
  reorderPoint Int      @default(0)
  costPrice    Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category     ProductCategory @relation(fields: [categoryId], references: [id])
  stocks          ProductStock[]
  moveLines       StockMoveLine[]
  adjustmentLines InventoryAdjustmentLine[]
}

model ProductStock {
  id         String   @id @default(cuid())
  productId  String
  locationId String
  onHand     Decimal  @default(0) @db.Decimal(12, 3)
  reserved   Decimal  @default(0) @db.Decimal(12, 3)
  updatedAt  DateTime @updatedAt

  product  Product  @relation(fields: [productId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([productId, locationId])
}

model StockPicking {
  id              String        @id @default(cuid())
  reference       String        @unique
  operationType   OperationType
  status          PickingStatus @default(DRAFT)
  fromLocationId  String?
  toLocationId    String?
  responsibleId   String?
  contactName     String?
  scheduledDate   DateTime?
  operationTypeLabel String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  doneAt          DateTime?

  fromLocation Location?      @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location?      @relation("ToLocation", fields: [toLocationId], references: [id])
  responsible  Profile?       @relation("ResponsibleReceipts", fields: [responsibleId], references: [id])
  lines        StockMoveLine[]

  @@index([operationType, status])
}

model StockMoveLine {
  id          String     @id @default(cuid())
  pickingId   String
  productId   String
  locationId  String?
  demandQty   Decimal    @db.Decimal(12, 3)
  doneQty     Decimal    @default(0) @db.Decimal(12, 3)
  status      MoveStatus @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  picking  StockPicking @relation(fields: [pickingId], references: [id], onDelete: Cascade)
  product  Product      @relation(fields: [productId], references: [id])
  location Location?    @relation(fields: [locationId], references: [id])
}

model StockLedger {
  id            String        @id @default(cuid())
  reference     String
  operationType OperationType
  productId     String
  productName   String
  fromLocation  String?
  toLocation    String?
  quantity      Decimal       @db.Decimal(12, 3)
  userId        String?
  userLoginId   String?
  createdAt     DateTime      @default(now())

  @@index([productId])
  @@index([reference])
  @@index([createdAt])
}

model InventoryAdjustment {
  id              String                    @id @default(cuid())
  reference       String                    @unique
  status          PickingStatus             @default(DRAFT)
  locationId      String
  responsibleId   String?
  notes           String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  location    Location                  @relation(fields: [locationId], references: [id])
  responsible Profile?                   @relation("ResponsibleAdjustments", fields: [responsibleId], references: [id])
  lines       InventoryAdjustmentLine[]

  @@index([status])
}

model InventoryAdjustmentLine {
  id           String              @id @default(cuid())
  adjustmentId String
  productId    String
  expectedQty  Decimal             @db.Decimal(12, 3)
  countedQty   Decimal             @db.Decimal(12, 3)
  diffQty      Decimal             @db.Decimal(12, 3)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  adjustment InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  product    Product             @relation(fields: [productId], references: [id])
}
